# LLM sağlayıcı anahtarları. EN AZ BİRİ gerekir; pipeline hepsini tek havuzda
# birleştirir ve birinde kota dolunca diğerine geçer (kotaları toplar).
# Yalnız değeri girilen sağlayıcı etkinleşir.

# Gemini (AI Studio ücretsiz): https://aistudio.google.com/apikey
GEMINI_API_KEY=
# İsteğe bağlı Gemini model havuzu (virgülle). Varsayılan: gemini-2.5-flash,...
# GEMINI_MODELS=gemini-2.5-flash,gemini-3.5-flash

# Groq (ücretsiz, hızlı): https://console.groq.com/keys
GROQ_API_KEY=
# Cerebras (ücretsiz, hızlı): https://cloud.cerebras.ai
CEREBRAS_API_KEY=
# Together AI (ücretsiz kredi): https://api.together.xyz/settings/api-keys
TOGETHER_API_KEY=
# Mistral (ücretsiz katman): https://console.mistral.ai/api-keys
MISTRAL_API_KEY=
# OpenRouter (ücretsiz modeller): https://openrouter.ai/keys
OPENROUTER_API_KEY=
# GitHub Models (GitHub token, ücretsiz preview): https://github.com/settings/tokens
GITHUB_MODELS_TOKEN=
