              "audioEnd": 63.138
            }
          ]
        },
        {
          "sentences": [
            {
              "text": "The panel was linked to a main power core that was still off due to the old storm.",
              "audioStart": 64,
              "audioEnd": 67.875
            },
            {
              "text": "Leo used a tool to open the panel and see the cable carefully while Maya watched.",
