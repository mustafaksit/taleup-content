            {
              "text": "They felt excited but also a little afraid.",
              "audioStart": 46.612,
              "audioEnd": 48.95
            },
            {
              "text": "After many hours, they reached the top of the mountain.",
              "audioStart": 49.812,
              "audioEnd": 52.587
