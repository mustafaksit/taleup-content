          ]
        },
        {
          "sentences": [
            {
              "text": "Leo turned the stone circles until they matched the sky.",
              "audioStart": 70.05,
              "audioEnd": 72.787
            },
            {
              "text": "Suddenly, the heavy door opened with a loud sound.",
              "audioStart": 73.65,
              "audioEnd": 76.425
            },
            {
              "text": "Inside the cave, everything was dark at first.",
              "audioStart": 77.287,
