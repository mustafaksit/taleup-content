            {
              "text": "Mia wanted to start the journey immediately.",
              "audioStart": 25.5,
              "audioEnd": 27.675
            },
            {
              "text": "They packed their bags with food and warm clothes.",
              "audioStart": 28.538,
              "audioEnd": 31.062
            },
            {
              "text": "Early the next day, they began their long climb toward the peak.",
              "audioStart": 31.925,
              "audioEnd": 35.3
            }
          ]
        },
        {
          "sentences": [
            {
              "text": "The mountain was very high and cold.",
