              "audioEnd": 126.412
            }
          ]
        },
        {
          "sentences": [
            {
              "text": "When Emily reach the fruit shop, she see Anna wait near a table with fresh fruit on show.",
              "audioStart": 127.275,
              "audioEnd": 132.05
            },
            {
              "text": "Anna say, run to Emily, and the two friends hold each other tight, feel great relief.",
